<?xml version="1.0"?>
<robot name="balancing_cube">

  <!-- ========================================== -->
  <!-- 1. ワールド（地面）の見えない固定アンカー -->
  <!-- ========================================== -->
  <!-- これがないと、キューブが地面を滑って逃げてしまいます -->
  <link name="world"/>

  <!-- ========================================== -->
  <!-- 2. 地面とキューブを繋ぐ蝶番（ヒンジ） -->
  <!-- ========================================== -->
  <!-- キューブの一辺を床に固定し、ロール軸(X軸)のみ回転できるようにします -->
  <joint name="floor_hinge" type="continuous">
    <parent link="world"/>
    <child link="cube_body"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="1 0 0"/> <!-- X軸を中心に回転する -->
    <dynamics damping="0.001" friction="0.001"/> <!-- 摩擦（少しいじるだけで動きが変わります） -->
  </joint>

  <!-- ========================================== -->
  <!-- 3. キューブ本体（The Cube） -->
  <!-- ========================================== -->
  <link name="cube_body">
    <visual>
      <!-- ヒンジ（原点）は一辺にあるので、重心を上にずらします（1辺10cmなら、Z=5cmの位置が中心） -->
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <!-- 【サイズ変更】1辺10cmの箱 -->
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="blue">
        <color rgba="0 0.5 1 0.8"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <!-- 【重さ変更】キューブ本体の重さ（例: 500g = 0.5kg） -->
      <!-- 実際の機体を作る時は、ケースや基板の重さの合計をここに入れます -->
      <mass value="0.5"/>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <!-- 慣性モーメント（適当な値ですが、厳密にやるなら計算値に入れます） -->
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!-- ========================================== -->
  <!-- 4. モーター関節（Motor Joint） -->
  <!-- ========================================== -->
  <!-- キューブとフライホイール（重り）を繋ぎます -->
  <joint name="motor" type="continuous">
    <parent link="cube_body"/>
    <child link="reaction_wheel"/>
    <!-- モーターの配置位置（キューブの中心に置くなら Z=0.05） -->
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <!-- 回転軸（X軸方向に回転） -->
    <axis xyz="1 0 0"/>
    <!-- 【モーターパワー変更】 effort=最大トルク, velocity=最大回転速度 -->
    <limit effort="1.0" velocity="100.0"/>
    <dynamics damping="0.01" friction="0.01"/>
  </joint>

  <!-- ========================================== -->
  <!-- 5. フライホイール（重り） -->
  <!-- ========================================== -->
  <link name="reaction_wheel">
    <visual>
      <!-- 円柱をX軸方向に向けるための回転 -->
      <origin xyz="0 0 0" rpy="0 1.570796 0"/>
      <geometry>
        <!-- 【重りサイズ変更】半径3cm、厚さ1cmの円柱 -->
        <cylinder radius="0.03" length="0.01"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <inertial>
      <!-- 【重り重さ変更】重りの質量（例: 100g = 0.1kg） -->
      <!-- ここを重くすると、小さな回転で大きなパワー（反作用）が出ます -->
      <mass value="0.1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- フライホイールの慣性モーメント。強化学習において非常に重要な数値です -->
      <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
    </inertial>
  </link>

</robot>
